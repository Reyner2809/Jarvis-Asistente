# ===========================================
# JARVIS - Configuracion de API Keys
# ===========================================
# Copia este archivo como .env y agrega tus keys
# Al menos UNA key es necesaria para funcionar

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-key-aqui

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-tu-key-aqui

# Google Gemini - https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-key-aqui

# ===========================================
# Configuracion del asistente
# ===========================================

# Proveedor preferido: claude, openai, gemini
AI_PROVIDER=claude

# Nombre del asistente
ASSISTANT_NAME=Jarvis

# Idioma de voz: es (espanol), en (ingles)
VOICE_LANGUAGE=es

# Velocidad de voz (palabras por minuto)
VOICE_SPEED=180

# Modelo preferido por proveedor
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro

# ===========================================
# Telegram (control remoto de Jarvis)
# ===========================================
# Crea tu bot con @BotFather (envia /newbot) y pega el token aqui.
# Si lo dejas vacio, Jarvis arranca normal pero sin soporte de Telegram.
TELEGRAM_BOT_TOKEN=

# IDs de Telegram autorizados a hablar con tu Jarvis (separa con coma).
# Obten tu ID hablando con @userinfobot en Telegram.
# OBLIGATORIO si TELEGRAM_BOT_TOKEN esta definido (por seguridad).
TELEGRAM_ALLOWED_USERS=

# Habilitar transcripcion de mensajes de voz desde Telegram (true/false).
# Requiere ffmpeg instalado en el PC donde corre Jarvis.
TELEGRAM_ENABLE_VOICE=true
