# ===========================================
# JARVIS - Configuracion
# ===========================================
# Copia este archivo como .env y ajusta segun tu hardware.
# Si usas setup.py, este archivo se genera automaticamente.

# ===========================================
# API Keys (opcional — solo si quieres usar modelos en la nube)
# ===========================================

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ===========================================
# Configuracion del asistente
# ===========================================

# Proveedor preferido: ollama (local, gratis), claude, openai, gemini
AI_PROVIDER=ollama

# Nombre del asistente
ASSISTANT_NAME=Jarvis

# Idioma de voz: es (espanol), en (ingles)
VOICE_LANGUAGE=es

# Velocidad de voz (palabras por minuto)
VOICE_SPEED=180

# Modelo preferido por proveedor (solo se usa si AI_PROVIDER lo elige)
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash

# ===========================================
# Modelos de Ollama (setup.py los selecciona automaticamente segun RAM)
# ===========================================

# Modelo principal (chat + agent loop con razonamiento profundo).
# 16GB+ RAM -> gemma4:e4b (avanzado, multimodal, ~5-15s por respuesta)
# <16GB RAM -> llama3.2 (ligero, funciona en cualquier PC)
OLLAMA_MODEL=gemma4:e4b

# Modelo router (clasificador de intenciones rapido, ~1s).
# Se usa en IntentRouter para decidir si un input es accion o pregunta.
# Mantener llama3.2 (rapido, 2GB) — no necesita razonamiento profundo.
OLLAMA_ROUTER_MODEL=llama3.2

# Fallback automatico si OLLAMA_MODEL falla
OLLAMA_FALLBACK_MODEL=llama3.2

# Modelo de vision (analisis de imagenes / capturas de pantalla)
# gemma4:e4b ya es multimodal. Usa llava solo si tu modelo principal no lo es.
OLLAMA_VISION_MODEL=llava

# ===========================================
# Telegram (control remoto de Jarvis)
# ===========================================
# Crea tu bot con @BotFather (envia /newbot) y pega el token aqui.
# Si lo dejas vacio, Jarvis arranca normal pero sin soporte de Telegram.
TELEGRAM_BOT_TOKEN=

# IDs de Telegram autorizados a hablar con tu Jarvis (separa con coma).
# Obten tu ID hablando con @userinfobot en Telegram.
# OBLIGATORIO si TELEGRAM_BOT_TOKEN esta definido (por seguridad).
TELEGRAM_ALLOWED_USERS=

# Habilitar transcripcion de mensajes de voz desde Telegram (true/false).
# Requiere ffmpeg instalado en el PC donde corre Jarvis.
TELEGRAM_ENABLE_VOICE=true
